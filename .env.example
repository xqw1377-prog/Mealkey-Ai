# ─── 数据库（默认开发环境使用 SQLite） ───
# Web 应用相对路径：apps/web/prisma/dev.db
DATABASE_URL="file:./dev.db"

# PostgreSQL（docker compose 默认）
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mealkey"

# ─── AI / LLM（二选一） ───
# 优先使用 DeepSeek
DEEPSEEK_API_KEY="sk-..."
# 备选 OpenAI
# OPENAI_API_KEY="sk-..."

# ─── 阿里云 DashScope（通义千问）— 语音转写 Paraformer ───
DASHSCOPE_API_KEY=""

# ─── Auth（生产环境必须设置强随机串，至少 16 位） ───
AUTH_SECRET="change-me-to-a-random-string-at-least-16"

# 平台管理员邮箱白名单（逗号分隔）。未配置时任何人都不具备管理员权限。
# PLATFORM_ADMIN_EMAILS="you@example.com"
# 产品界面语言（默认 zh-CN；可选 zh-TW / en / ja）
# NEXT_PUBLIC_MEALKEY_LOCALE=zh-CN

# Host 信任：生产应设 AUTH_TRUST_HOST=false
# AUTH_TRUST_HOST=true
# 本机开发验收管理台旁路（仅 NODE_ENV≠production 且 Host 为 localhost）。
# 公网隧道不要开；默认关闭。需要时显式：
# MK_ALLOW_PUBLIC_PREVIEW_AUTH=1

# Vercel Cron / 运维巡检密钥（生产必须 ≥16 位；未配则生产 Cron 拒绝）
CRON_SECRET="replace-with-long-random-at-least-16"
# 手动预检：GET /api/cron/reconcile-payments?dryRun=1
# Header: Authorization: Bearer $CRON_SECRET
# 说明：查渠道后已付补发货 / 未付关单 / 查单失败跳过

# 支付模式：开发默认 sandbox；生产必须配微信/支付宝，勿依赖 sandbox
# PAYMENT_MODE="live"
# 生产显式允许沙箱（默认禁止；仅应急验收）：
# PAYMENT_ALLOW_SANDBOX=1

# ─── App ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── 联网搜索（可选，零配置默认使用 DuckDuckGo 免费 API） ───
# SearXNG 自建实例（推荐，无速率限制）
# SEARXNG_URL="http://localhost:8888"
# SerpAPI（付费，最稳定）
# SERPAPI_KEY="..."

# ─── 可选 ───
# REDIS_URL="redis://localhost:6379"
# SKIP_ENV_VALIDATION=1

# ─── 分布式限流（生产必须；未配则限流 fail-closed，除非 RATE_LIMIT_ALLOW_MEMORY=1）───
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="replace-me"
# 应急才开（多实例下内存桶无效，勿长期使用）：
# RATE_LIMIT_ALLOW_MEMORY=1

# ─── 平台事件接入（生产必须配置，否则 /api/platform/events 拒绝）───
# MK_EVENT_INGEST_TOKEN="replace-me"
# MK_EVENT_INGEST_TOKENS="token-a,token-b"
# MK_EVENT_SIGNING_SECRET="replace-me"

# ─── 文件存储 ───
# 本地开发可用 local；生产环境校验强制 BLOB_STORAGE_PROVIDER=s3
BLOB_STORAGE_PROVIDER=local
# BLOB_LOCAL_ROOT=

# 生产 Serverless / 本地 MinIO / Cloudflare R2（生产必须 s3）：
# BLOB_STORAGE_PROVIDER=s3
# S3_BUCKET=mealkey-assets
# S3_REGION=us-east-1
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_FORCE_PATH_STYLE=true
# S3_PUBLIC_BASE_URL=http://127.0.0.1:9000/mealkey-assets
# S3_ACCESS_KEY_ID=mealkey
# S3_SECRET_ACCESS_KEY=mealkeysecret

# ─── Agent Platform Gateway（生产必须；禁止默认明文）───
# MK_AGENT_SECRET_KEK="replace-with-random-at-least-16"
# MK_AGENT_SANDBOX_SECRET="replace-with-non-default-secret"
# MK_AGENT_REGISTRY_JSON=
# MK_GATEWAY_USER_TOKENS="token|ownerId"
# 生产勿开：
# MK_GATEWAY_SKIP_INSTALL_CHECK=1
# MK_GATEWAY_DEV_OPEN=1
# MK_GATEWAY_ALLOW_SANDBOX_TOKEN=1

# ─── 外呼引擎 / LIVE（生产勿开降级放行）───
# HEURISTIC_ONLY=false
# FOUNDER_ALLOW_DEGRADED_MEETING=   # 生产勿设为 1；设为 1 会允许启发式开会并扣点（仅演示）
# LIVE_AGENTS=1                      # 仅本地跑 npm run test:live-agents 时使用
# MBIZ_API_BASE_URL=http://127.0.0.1:8000/api/v1/bmjm
# MBIZ_API_TOKEN=mbiz-dev-token-2026
# MED_API_BASE_URL=http://127.0.0.1:8001
# MMKT_API_BASE_URL=http://127.0.0.1:8002

# ─── 支付（微信 / 支付宝；开发默认 sandbox，可模拟支付）───
# PAYMENT_MODE=sandbox
# APP_URL="http://localhost:3000"

# 微信支付 V3 Native + H5（微信内优先 H5，失败回退 Native 扫码；设 WECHAT_PAY_H5_ENABLED=0 可关）
# WECHAT_PAY_H5_ENABLED=1
# WECHAT_PAY_APP_ID=
# WECHAT_PAY_MCH_ID=
# WECHAT_PAY_SERIAL_NO=
# WECHAT_PAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# WECHAT_PAY_API_V3_KEY=
# WECHAT_PAY_NOTIFY_URL="https://your.domain/api/billing/notify/wechat"
# 生产回调强制 RSA 验签，必须配置平台公钥：
# WECHAT_PAY_PLATFORM_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# 支付宝电脑网站支付
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=
# ALIPAY_NOTIFY_URL="https://your.domain/api/billing/notify/alipay"
# ALIPAY_RETURN_URL="https://your.domain/billing"
# ALIPAY_GATEWAY="https://openapi.alipay.com/gateway.do"
