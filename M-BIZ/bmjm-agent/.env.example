# BMJM Agent 环境变量模板
# 复制为 .env 并填入实际值

# ====== 鉴权 ======
BMJM_AUTH_ENABLED=true
BMJM_API_TOKEN=your-secret-token-here
BMJM_API_KEY=your-api-key-here

# ====== 服务 ======
BMJM_HOST=0.0.0.0
BMJM_PORT=8000
BMJM_LOG_LEVEL=INFO

# ====== LLM (可选，不配则使用纯规则模式) ======
BMJM_LLM_PROVIDER=openai
BMJM_LLM_MODEL=gpt-4o-mini
BMJM_LLM_API_KEY=
BMJM_LLM_API_BASE=
