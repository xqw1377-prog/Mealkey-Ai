# ─── 数据库（默认开发环境使用 SQLite） ───
# Web 应用相对路径：apps/web/prisma/dev.db
DATABASE_URL="file:./dev.db"

# PostgreSQL（docker compose 默认）
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mealkey"

# ─── AI / LLM（二选一） ───
# 优先使用 DeepSeek
DEEPSEEK_API_KEY="sk-..."
# 备选 OpenAI
# OPENAI_API_KEY="sk-..."

# ─── 阿里云 DashScope（通义千问）— 语音转写 Paraformer ───
DASHSCOPE_API_KEY=""

# ─── Auth（生产环境必须设置强随机串，至少 16 位） ───
AUTH_SECRET="change-me-to-a-random-string-at-least-16"

# 平台管理员邮箱白名单（逗号分隔）。未配置时任何人都不具备管理员权限。
# PLATFORM_ADMIN_EMAILS="you@example.com"

# Host 信任：生产可设 AUTH_TRUST_HOST=false 收紧
# AUTH_TRUST_HOST=true
# 公网预览隧道（如 cloudflared）调试时再开启：
# MK_ALLOW_PUBLIC_PREVIEW_AUTH=true

# ─── App ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── M-BIZ 外呼（可选；生产必须配置 Token，禁止依赖默认开发值）───
# MBIZ_API_BASE_URL="http://127.0.0.1:8000/api/v1/bmjm"
# MBIZ_API_TOKEN="replace-me"

# ─── 联网搜索（可选，零配置默认使用 DuckDuckGo 免费 API） ───
# SearXNG 自建实例（推荐，无速率限制）
# SEARXNG_URL="http://localhost:8888"
# SerpAPI（付费，最稳定）
# SERPAPI_KEY="..."

# ─── 可选 ───
# REDIS_URL="redis://localhost:6379"
# SKIP_ENV_VALIDATION=1

# ─── 分布式限流（生产多实例强烈建议）───
# UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="..."

# ─── 平台事件接入（生产必须配置，否则 /api/platform/events 拒绝）───
# MK_EVENT_INGEST_TOKEN="replace-me"
# MK_EVENT_INGEST_TOKENS="token-a,token-b"
# MK_EVENT_SIGNING_SECRET="replace-me"

# ─── 文件存储（默认 local → apps/web/private/uploads，经鉴权 API 下载） ───
# BLOB_STORAGE_PROVIDER=local
# BLOB_LOCAL_ROOT=

# 生产 Serverless / 本地 MinIO / Cloudflare R2（生产必须 s3）：
# BLOB_STORAGE_PROVIDER=s3
# S3_BUCKET=mealkey-assets
# S3_REGION=us-east-1
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_FORCE_PATH_STYLE=true
# S3_PUBLIC_BASE_URL=http://127.0.0.1:9000/mealkey-assets
# S3_ACCESS_KEY_ID=mealkey
# S3_SECRET_ACCESS_KEY=mealkeysecret

# ─── 支付（微信 / 支付宝；开发默认 sandbox，可模拟支付）───
# PAYMENT_MODE=sandbox
# APP_URL="http://localhost:3000"

# 微信支付 V3 Native
# WECHAT_PAY_APP_ID=
# WECHAT_PAY_MCH_ID=
# WECHAT_PAY_SERIAL_NO=
# WECHAT_PAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# WECHAT_PAY_API_V3_KEY=
# WECHAT_PAY_NOTIFY_URL="https://your.domain/api/billing/notify/wechat"
# WECHAT_PAY_PLATFORM_PUBLIC_KEY=

# 支付宝电脑网站支付
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=
# ALIPAY_NOTIFY_URL="https://your.domain/api/billing/notify/alipay"
# ALIPAY_RETURN_URL="https://your.domain/billing"
# ALIPAY_GATEWAY="https://openapi.alipay.com/gateway.do"
