{
  "name": "@mealkey/agents",
  "version": "0.1.0",
  "private": true,
  "description": "MealKey Agent 产品矩阵: LaunchAgent（开店顾问）+ MPntAgent（餐饮定位）",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./launch": {
      "types": "./dist/launch/index.d.ts",
      "import": "./dist/launch/index.js",
      "default": "./dist/launch/index.js"
    },
    "./m-pnt": {
      "types": "./dist/m-pnt/index.d.ts",
      "import": "./dist/m-pnt/index.js",
      "default": "./dist/m-pnt/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "@mealkey/agent-sdk": "*"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
