MK_GATEWAY_URL=http://localhost:3000/api
# 仅服务端 / CLI 使用，勿写入 VITE_* 暴露到浏览器
MK_AGENT_SECRET=
MK_AGENT_ID=restaurant-diagnosis
# sandbox | production（production 必须已安装，禁止静默降级）
MK_GATEWAY_MODE=sandbox
# 生产 Context 租用时必填
# MK_RESTAURANT_ID=
# MK_USER_ACCESS_TOKEN=
MK_FIXTURE_ID=changsha-xiangcai-a

# ─── 本地 Backend 旁路（非 Architecture Freeze 的 Host 路径）───
M_OPS_BACKEND_PORT=8787
M_OPS_BACKEND_HOST=127.0.0.1
# 建议本地也设置；未设置时除 /api/store/clear 外本机开放
M_OPS_BACKEND_TOKEN=dev-local-token
M_OPS_BACKEND_CORS_ORIGIN=http://localhost:5173
M_OPS_BACKEND_MAX_BODY_BYTES=1048576
# synthetic（默认 fixture）| live（需 registerLiveCollector）
M_OPS_COLLECTOR_MODE=synthetic
# M_OPS_DIAG_STORE_PATH=

VITE_OS_WEB_URL=http://localhost:3000
VITE_BACKEND_URL=http://localhost:8787
VITE_BACKEND_TOKEN=dev-local-token

# ─── 小程序 Shell（在 miniprogram/app.js globalData 填写同址）───
# authApiUrl  → http://127.0.0.1:8787  （POST /wechat/session）
# brainApiUrl → http://127.0.0.1:8787  （POST /brain/sync）
# marketplaceUrl → 远程 JSON（可选；本地已有 host/marketplace.sample.js）
# 浏览器 Gateway 同步时再填；留空则跳过同步
# VITE_MK_AGENT_SECRET=
# VITE_MK_GATEWAY_URL=/api
# VITE_MK_GATEWAY_MODE=sandbox
# VITE_MK_USER_ACCESS_TOKEN=
# VITE_MK_USE_GATEWAY_CONTEXT=1
