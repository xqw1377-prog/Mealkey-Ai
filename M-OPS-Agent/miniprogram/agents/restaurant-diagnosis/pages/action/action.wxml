<view class="page" wx:if="{{ready}}">
  <view class="card share-card">
    <text class="kicker">餐启 · 本周经营动作卡</text>
    <text class="store">{{restaurantName}}</text>
    <view class="block">
      <text class="label">一句话主因</text>
      <text class="body">{{bossBrief}}</text>
    </view>
    <view class="block focus">
      <text class="label">本周只做这一件</text>
      <text class="action">{{weekAction}}</text>
    </view>
    <view class="block">
      <text class="label">怎么验证</text>
      <view class="v" wx:for="{{validations}}" wx:for-index="idx" wx:key="*this">{{idx + 1}}. {{item}}</view>
    </view>
    <text class="foot">规则体检 · 全免 · 非大模型</text>
  </view>

  <button class="btn btn-block" bindtap="copyShare">复制分享文案</button>
  <button class="btn btn-ghost btn-block gap" bindtap="backReport">返回报告</button>
</view>

<view class="page" wx:else>
  <text class="lede">暂无动作卡，请先完成体检。</text>
  <button class="btn btn-block gap" bindtap="goHome">返回 MealKey</button>
</view>
