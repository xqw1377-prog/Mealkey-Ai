<view class="page">
  <text class="kicker">经营节奏</text>
  <text class="h1">我的体检档案</text>
  <text class="lede">本机最多保留 10 轮。点开可重看会审；再次导入数据可复检对比。</text>

  <view class="empty" wx:if="{{!items.length}}">
    <text class="muted">还没有档案。先完成一次「体检我的店」。</text>
    <button class="btn btn-block gap" bindtap="goExam">去体检</button>
  </view>

  <view class="card" wx:for="{{items}}" wx:key="id" data-id="{{item.id}}" bindtap="openItem">
    <view class="row">
      <text class="name">{{item.restaurantName}}</text>
      <text class="mode">{{item.examModeLabel}}</text>
    </view>
    <text class="verdict">{{item.overallVerdict}}</text>
    <text class="brief">{{item.bossBrief}}</text>
    <text class="action" wx:if="{{item.weekAction}}">动作：{{item.weekAction}}</text>
    <text class="muted">{{item.atLabel}}</text>
  </view>
</view>
