.page {
  padding: 40rpx 36rpx 80rpx;
}

.empty {
  margin-top: 40rpx;
}

.card {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 1rpx solid var(--line);
  background: var(--card);
}

.row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.name {
  font-weight: 600;
  font-size: 28rpx;
}

.mode {
  font-size: 22rpx;
  color: var(--olive);
}

.verdict {
  display: block;
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.brief {
  display: block;
  font-size: 24rpx;
  color: var(--muted);
  margin-bottom: 8rpx;
}

.action {
  display: block;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.gap {
  margin-top: 24rpx;
}
