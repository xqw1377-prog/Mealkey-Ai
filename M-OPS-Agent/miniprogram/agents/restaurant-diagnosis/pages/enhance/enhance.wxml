<view class="page">
  <text class="kicker">能力边界</text>
  <text class="h1">首诊在微信 · 长期在经营大脑</text>
  <text class="lede">体检不依赖下载 App。下列对照：小程序交付首价值；MealKey 沉淀每日经营。</text>

  <view class="section">
    <text class="section-title">微信小程序（已具备）</text>
    <view class="item" wx:for="{{mpItems}}" wx:key="title">
      <text class="item-title">{{item.title}}</text>
      <text class="muted">{{item.desc}}</text>
    </view>
  </view>

  <view class="section">
    <text class="section-title">仅 Mealkey App / 母体</text>
    <view class="item" wx:for="{{mkItems}}" wx:key="title">
      <text class="item-title">{{item.title}}</text>
      <text class="muted">{{item.desc}}</text>
    </view>
  </view>

  <view class="banner">
    <text class="banner-title">导出交接证据包（可选）</text>
    <text class="banner-body">把本次会审摘要复制为 JSON，便于在 Mealkey 粘贴增强档案。不上传、不抓取。</text>
    <button class="btn btn-block" disabled="{{!hasResult}}" bindtap="exportHandoff">复制交接证据包</button>
  </view>

  <view class="banner soft">
    <text class="banner-title">复检提醒</text>
    <text class="banner-body">{{remindLabel}}</text>
    <button class="btn btn-ghost btn-block" bindtap="setRemind7">设为 7 天后复检</button>
    <button class="btn btn-ghost btn-block gap" bindtap="clearRemind">清除提醒</button>
  </view>

  <button class="btn btn-block gap" bindtap="downloadApp">进入 MealKey 经营大脑</button>
</view>
