.page {
  padding: 40rpx 36rpx 100rpx;
}

.section {
  margin-top: 32rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--line);
}

.section-title {
  display: block;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.item {
  margin-bottom: 18rpx;
}

.item-title {
  display: block;
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.banner {
  margin-top: 32rpx;
  padding: 24rpx;
  border: 1rpx solid var(--line);
  background: var(--card);
}

.banner.soft {
  border-style: dashed;
}

.banner-title {
  display: block;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.banner-body {
  display: block;
  font-size: 24rpx;
  color: var(--muted);
  margin-bottom: 16rpx;
}

.gap {
  margin-top: 16rpx;
}
