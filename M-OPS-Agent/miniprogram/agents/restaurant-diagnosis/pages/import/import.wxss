.page {
  padding: 40rpx 36rpx 100rpx;
}

.field,
.block {
  margin-top: 28rpx;
}

.label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.label {
  display: block;
  font-size: 24rpx;
  color: var(--muted);
  margin-bottom: 10rpx;
}

.label-row .label {
  margin-bottom: 0;
}

.help {
  display: block;
  font-size: 22rpx;
  color: var(--muted);
  margin: 8rpx 0 12rpx;
  line-height: 1.4;
}

.link {
  font-size: 24rpx;
  color: var(--olive);
}

.input {
  border: 1rpx solid var(--line);
  background: var(--card);
  padding: 18rpx 22rpx;
  font-size: 28rpx;
  min-height: 76rpx;
}

.row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.half {
  flex: 1;
}

.area {
  width: 100%;
  min-height: 220rpx;
  border: 1rpx solid var(--line);
  background: var(--card);
  padding: 16rpx;
  font-size: 22rpx;
  box-sizing: border-box;
}

.area.short {
  min-height: 160rpx;
}

.btn-mini {
  margin: 0;
  padding: 0 24rpx;
  min-height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
  background: var(--ink);
  color: #f6f3ed;
  border-radius: 0;
}

.btn-mini.ghost {
  background: transparent;
  color: var(--ink);
  border: 1rpx solid var(--line);
}

.btn-mini::after {
  border: none;
}

.preview {
  margin-top: 16rpx;
  padding: 16rpx;
  border: 1rpx solid var(--line);
  background: var(--card);
}

.tag-row {
  margin-bottom: 12rpx;
}

.tag {
  display: block;
  font-size: 22rpx;
  color: var(--olive);
}

.claim {
  display: block;
  font-size: 24rpx;
}

.qc {
  margin-top: 28rpx;
  padding: 20rpx;
  border: 1rpx solid var(--line);
  background: rgba(119, 128, 95, 0.06);
}

.qc-title {
  display: block;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.gauge {
  margin: 12rpx 0 16rpx;
}

.gauge-row {
  margin-bottom: 10rpx;
  font-size: 22rpx;
}

.bar-wrap {
  margin-top: 6rpx;
  height: 12rpx;
  background: rgba(20, 20, 19, 0.08);
}

.bar {
  height: 100%;
  background: var(--olive);
}

.bar.soft {
  background: rgba(119, 128, 95, 0.55);
}

.check {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  margin-bottom: 6rpx;
}

.qc-sum {
  display: block;
  font-size: 26rpx;
  margin-bottom: 12rpx;
}

.ok {
  font-size: 22rpx;
  color: var(--olive);
  margin-bottom: 6rpx;
}

.hard {
  font-size: 22rpx;
  color: #a33;
  margin-bottom: 6rpx;
}

.soft {
  font-size: 22rpx;
  color: #8a6a2f;
  margin-bottom: 6rpx;
}

.err {
  display: block;
  color: #a33;
  font-size: 24rpx;
  margin: 20rpx 0;
}

.gap {
  margin-top: 20rpx;
}
