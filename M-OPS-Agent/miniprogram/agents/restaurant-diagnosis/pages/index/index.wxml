<view class="page">
  <view class="agent-bar">
    <text class="link-back" bindtap="goShell">← MealKey</text>
    <text class="agent-id">Agent · restaurant-diagnosis</text>
  </view>

  <text class="kicker">第一个挂载能力</text>
  <text class="h1">餐厅经营体检</text>
  <text class="lede">用账本与评论完成可核验会审。结果写入 Shell 共享 Brain。</text>
  <text class="muted" wx:if="{{restaurantHint}}">当前店：{{restaurantHint}}</text>

  <view class="banner free" wx:if="{{hasArchive}}">
    <text class="banner-title">可复检</text>
    <text class="banner-body">上次：{{lastVerdict}}（{{lastAt}}）</text>
  </view>

  <view class="banner upgrade" wx:if="{{remindDue}}">
    <text class="banner-title">复检日到了</text>
    <text class="banner-body">{{remindLabel}}</text>
    <button class="btn btn-block banner-btn" bindtap="goImport">导入新数据复检</button>
  </view>

  <view class="section">
    <button class="btn btn-block" bindtap="goMyExam">体检我的店</button>
    <button class="btn btn-ghost btn-block gap" bindtap="goImport">已有表？直接导入</button>
    <button class="btn btn-ghost btn-block gap" bindtap="goArchive">我的档案 / 复检</button>
  </view>

  <view class="fold" bindtap="toggleDemo">
    <text class="fold-title">演示示例（合成数据）{{showDemo ? '▴' : '▾'}}</text>
  </view>
  <view class="demo" wx:if="{{showDemo}}">
    <text class="muted">仅演示引擎，不代表你的店。</text>
    <view class="pack-row">
      <button class="pack {{packId==='xiangcai'?'on':''}}" data-id="xiangcai" bindtap="pickPack">湘菜</button>
      <button class="pack {{packId==='hotpot'?'on':''}}" data-id="hotpot" bindtap="pickPack">火锅</button>
      <button class="pack {{packId==='tea'?'on':''}}" data-id="tea" bindtap="pickPack">茶饮</button>
    </view>
    <text class="pack-tip">{{packTip}}</text>
    <button class="btn btn-ghost btn-block" bindtap="goDemo">运行演示体检</button>
  </view>

  <view class="banner soft">
    <text class="banner-title">完诊后</text>
    <text class="banner-body">可回 Shell「大脑」看档案，或进入 MealKey 经营大脑做每日跟踪。</text>
    <button class="btn btn-ghost btn-block banner-btn" bindtap="goShell">返回 MealKey 框架</button>
    <button class="btn btn-ghost btn-block banner-btn gap" bindtap="downloadApp">进入经营大脑</button>
  </view>
</view>
