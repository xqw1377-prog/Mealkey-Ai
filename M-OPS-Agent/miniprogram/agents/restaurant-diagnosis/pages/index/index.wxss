.page {
  padding: 48rpx 40rpx 80rpx;
}

.brand-row {
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.mark {
  width: 80rpx;
  height: 80rpx;
  background: #141413;
  color: #f6f3ed;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.brand-copy {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.banner {
  margin-top: 28rpx;
  padding: 28rpx;
  border: 1rpx solid var(--line);
  background: var(--card);
}

.banner.free {
  border-color: rgba(119, 128, 95, 0.45);
  background: rgba(119, 128, 95, 0.08);
}

.banner.soft {
  margin-top: 40rpx;
}

.banner.upgrade {
  border-color: rgba(160, 90, 40, 0.4);
  background: rgba(160, 90, 40, 0.08);
}

.banner-title {
  display: block;
  font-weight: 600;
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.banner-body {
  display: block;
  color: var(--muted);
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.banner-btn {
  margin-top: 8rpx;
}

.fold {
  margin-top: 40rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid var(--line);
}

.fold-title {
  font-size: 24rpx;
  color: var(--muted);
}

.demo {
  padding: 16rpx 0 8rpx;
}

.pack-row {
  display: flex;
  gap: 12rpx;
  margin: 16rpx 0 12rpx;
}

.pack {
  flex: 1;
  margin: 0;
  min-height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  background: transparent;
  border: 1rpx solid var(--line);
  color: var(--ink);
  border-radius: 0;
  padding: 0;
}

.pack.on {
  background: var(--ink);
  color: #f6f3ed;
  border-color: var(--ink);
}

.pack::after {
  border: none;
}

.pack-tip {
  display: block;
  font-size: 22rpx;
  color: var(--muted);
  margin: 8rpx 0 16rpx;
  line-height: 1.45;
}

.gap {
  margin-top: 20rpx;
}

.agent-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.link-back {
  color: var(--olive);
  font-size: 24rpx;
}

