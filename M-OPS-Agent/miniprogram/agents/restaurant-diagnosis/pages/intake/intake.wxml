<view class="page">
  <text class="kicker">第 1 步 · 认识门店</text>
  <text class="h1">体检我的店</text>
  <text class="lede">先留下门店画像，下一步导入你的账本与评论。全免，独立完成。</text>

  <view class="form">
    <view class="field">
      <text class="label">店名</text>
      <input class="input" placeholder="例如：湘味小馆" value="{{name}}" bindinput="onName" />
    </view>
    <view class="field">
      <text class="label">城市</text>
      <input class="input" placeholder="例如：长沙" value="{{city}}" bindinput="onCity" />
    </view>
    <view class="field">
      <text class="label">品类</text>
      <input class="input" placeholder="湘菜 / 火锅 / 茶饮…" value="{{category}}" bindinput="onCategory" />
    </view>
    <view class="field">
      <text class="label">人均体感</text>
      <input class="input" placeholder="例如：人均约 78" value="{{priceRange}}" bindinput="onPrice" />
    </view>
    <view class="field">
      <text class="label">你现在最想知道什么？</text>
      <radio-group bindchange="onFocus">
        <label class="radio" wx:for="{{focusOptions}}" wx:key="id">
          <radio value="{{item.id}}" checked="{{focus===item.id}}" color="#141413" />
          <text>{{item.label}}</text>
        </label>
      </radio-group>
    </view>
  </view>

  <button class="btn btn-block" bindtap="nextImport">下一步：导入数据</button>
  <button class="btn btn-ghost btn-block gap" bindtap="runQuick">先浅检（仅画像+演示评论）</button>
</view>
