.page {
  padding: 40rpx 36rpx 100rpx;
}

.hero {
  margin-bottom: 28rpx;
}

.layer {
  margin-bottom: 28rpx;
}

.layer-2 {
  padding: 24rpx;
  border: 1rpx solid var(--line);
  background: var(--card);
}

.week-action {
  display: block;
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
}

.pack-tip {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--muted);
}

.fold-head {
  padding: 16rpx 0;
}

.brief {
  margin: 20rpx 0;
  padding: 22rpx;
  border-left: 6rpx solid var(--olive);
  background: var(--card);
}

.brief-label {
  display: block;
  font-size: 22rpx;
  color: var(--olive);
  letter-spacing: 0.08em;
  margin-bottom: 8rpx;
}

.brief-body {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 1.45;
}

.banner {
  padding: 24rpx;
  border: 1rpx solid var(--line);
  background: var(--card);
  margin-bottom: 16rpx;
}

.banner.soft {
  margin-top: 8rpx;
}

.banner.upgrade {
  border-color: var(--olive);
  background: rgba(119, 128, 95, 0.1);
  margin-bottom: 20rpx;
}

.banner-title {
  display: block;
  font-weight: 600;
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.done-note {
  display: block;
  margin-top: 12rpx;
}

.delta,
.dna {
  padding: 20rpx;
  border: 1rpx solid var(--line);
  background: var(--card);
}

.weight {
  margin-top: 12rpx;
  font-size: 24rpx;
}

.bar-wrap {
  margin-top: 6rpx;
  height: 10rpx;
  background: rgba(20, 20, 19, 0.08);
}

.bar {
  height: 100%;
  background: var(--olive);
}

.banner .bullet {
  display: block;
  font-size: 22rpx;
  color: var(--muted);
  margin-bottom: 6rpx;
}

.banner-body {
  display: block;
  color: var(--muted);
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.section {
  margin-top: 36rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--line);
}

.section-title {
  display: block;
  font-weight: 600;
  font-size: 30rpx;
  margin-bottom: 12rpx;
}

.module-summary {
  display: block;
  color: var(--muted);
  font-size: 26rpx;
  margin-bottom: 12rpx;
}

.bullet {
  font-size: 26rpx;
  margin-bottom: 8rpx;
  color: var(--ink);
}

.expert {
  margin-bottom: 20rpx;
}

.expert-title {
  display: block;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.gap {
  margin-top: 32rpx;
}

.tip {
  font-size: 22rpx;
}
