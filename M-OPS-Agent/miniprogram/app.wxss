page {
  --ink: #141413;
  --muted: #6b6a64;
  --olive: #77805f;
  --paper: #f6f3ed;
  --line: rgba(20, 20, 19, 0.12);
  --card: #fffcf7;
  background: var(--paper);
  color: var(--ink);
  font-size: 28rpx;
  line-height: 1.55;
  box-sizing: border-box;
}

.muted {
  color: var(--muted);
  font-size: 22rpx;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 0 32rpx;
  border-radius: 0;
  border: 1rpx solid var(--ink);
  background: var(--ink);
  color: #f6f3ed;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-ghost {
  background: transparent;
  color: var(--ink);
}

.btn-block {
  width: 100%;
}

.section {
  margin-top: 40rpx;
}

.kicker {
  color: var(--olive);
  font-size: 22rpx;
  letter-spacing: 0.12em;
  margin-bottom: 8rpx;
}

.h1 {
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1.3;
  margin: 0 0 12rpx;
}

.lede {
  color: var(--muted);
  font-size: 26rpx;
  margin: 0;
}

/* Shell 框架共用 */
.shell-page {
  min-height: 100vh;
  box-sizing: border-box;
}

.page {
  padding: 40rpx 36rpx 80rpx;
  box-sizing: border-box;
}
