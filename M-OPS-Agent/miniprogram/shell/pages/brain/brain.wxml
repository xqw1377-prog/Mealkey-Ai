<view class="page shell-page">
  <text class="kicker">Restaurant Brain</text>
  <text class="h1">餐厅经营档案</text>
  <text class="lede">跨 Agent 共享。从体检进其他能力，默认同一家店。</text>

  <view class="banner" wx:if="{{restaurant}}">
    <text class="banner-title">{{restaurant.name}}</text>
    <text class="banner-body">{{meta}}</text>
  </view>
  <view class="banner soft" wx:else>
    <text class="banner-body">还没有餐厅。先打开「餐厅经营体检」Agent，档案会自动写入。</text>
    <button class="btn btn-block gap" bindtap="openDiagnosis">打开首个 Agent</button>
  </view>

  <view class="section" wx:if="{{runs.length}}">
    <text class="section-title">最近 Run</text>
    <view class="run" wx:for="{{runs}}" wx:key="id">
      <text>{{item.overallVerdict || item.summary || item.agentId}}</text>
      <text class="muted">{{item.at}} · {{item.agentId}}</text>
    </view>
  </view>

  <button class="btn btn-block gap" bindtap="enterBrain">进入 MealKey 经营大脑</button>
</view>
