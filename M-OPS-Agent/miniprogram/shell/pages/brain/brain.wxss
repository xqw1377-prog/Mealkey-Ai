.page {
  padding: 40rpx 36rpx 80rpx;
}

.banner {
  margin-top: 28rpx;
  padding: 28rpx;
  border: 1rpx solid var(--line);
  background: var(--card);
}

.banner.soft {
  border-style: dashed;
}

.banner-title {
  display: block;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.banner-body {
  display: block;
  color: var(--muted);
  font-size: 24rpx;
}

.section-title {
  display: block;
  font-weight: 600;
  margin: 32rpx 0 12rpx;
}

.run {
  padding: 12rpx 0;
  border-top: 1rpx solid var(--line);
}

.gap {
  margin-top: 20rpx;
}
