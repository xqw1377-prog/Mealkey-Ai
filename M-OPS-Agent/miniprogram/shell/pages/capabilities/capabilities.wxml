<view class="page shell-page">
  <text class="kicker">能力市场</text>
  <text class="h1">可插拔 Agent</text>
  <text class="lede">在 Shell 内打开能力，共享 Restaurant Brain。不是另装小程序。</text>

  <view class="agent-card" wx:for="{{agents}}" wx:key="agentId">
    <view class="agent-row">
      <text class="agent-name">{{item.displayName}}</text>
      <text class="tag">{{item.status === 'live' ? '已上架' : '即将上架'}}</text>
    </view>
    <text class="muted">{{item.family}} · {{item.tokenCost || 0}} Token</text>
    <text class="muted block">{{item.summary}}</text>
    <button class="btn btn-ghost btn-block gap" data-id="{{item.agentId}}" bindtap="openAgent">
      {{item.status === 'live' ? '打开能力' : '了解'}}
    </button>
  </view>
</view>
