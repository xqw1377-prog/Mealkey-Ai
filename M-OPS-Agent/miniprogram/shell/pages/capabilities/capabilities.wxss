.shell-page {
  padding: 40rpx 36rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.agent-card {
  margin-top: 28rpx;
  padding: 24rpx;
  border: 1rpx solid var(--line);
  background: var(--card);
}

.agent-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.agent-name {
  font-size: 32rpx;
  font-weight: 600;
}

.tag {
  font-size: 20rpx;
  color: var(--olive);
}

.block {
  display: block;
  margin-top: 8rpx;
}

.gap {
  margin-top: 16rpx;
}
