<view class="page shell-page">
  <view class="brand-row">
    <view class="mark">M</view>
    <view class="brand-copy">
      <text class="kicker">MealKey Mini Shell</text>
      <text class="h1">餐饮 AI 超级入口</text>
    </view>
  </view>

  <text class="lede">一个小程序挂载多个 Agent。下方 Tab 是平台框架；能力在「能力」里打开。</text>
  <text class="muted token-line">Token {{balance}} · 欢迎额度覆盖首价值</text>

  <view class="banner free" wx:if="{{hasRestaurant}}">
    <text class="banner-title">当前餐厅（Brain）</text>
    <text class="banner-body">{{restaurantName}} · {{restaurantMeta}}</text>
    <button class="btn btn-ghost btn-block banner-btn" bindtap="goBrain">查看经营档案</button>
  </view>
  <view class="banner soft" wx:else>
    <text class="banner-title">尚未建立餐厅档案</text>
    <text class="banner-body">打开下方首个 Agent「餐厅经营体检」，档案将写入共享 Brain，供后续能力复用。</text>
  </view>

  <view class="section">
    <text class="section-title">首个 Agent · 已上架</text>
    <view class="hero-agent" bindtap="openDiagnosis">
      <text class="agent-name">餐厅经营体检</text>
      <text class="muted">restaurant-diagnosis · 账本+评论 → 四官会审</text>
      <button class="btn btn-block gap" catchtap="openDiagnosis">进入体检</button>
    </view>
  </view>

  <view class="section" wx:if="{{agents.length}}">
    <view class="section-head">
      <text class="section-title">全部挂载</text>
      <text class="link" bindtap="goCapabilities">能力市场</text>
    </view>
    <view
      class="agent-row-item"
      wx:for="{{agents}}"
      wx:key="agentId"
      data-id="{{item.agentId}}"
      bindtap="openAgent"
    >
      <view class="agent-row">
        <text class="agent-name">{{item.displayName}}</text>
        <text class="tag">{{item.status === 'live' ? '可用' : '即将上架'}}</text>
      </view>
      <text class="muted">{{item.summary}}</text>
    </view>
  </view>
</view>
