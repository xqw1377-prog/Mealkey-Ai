.shell-page {
  padding: 40rpx 36rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.brand-row {
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.mark {
  width: 80rpx;
  height: 80rpx;
  background: #141413;
  color: #f6f3ed;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.brand-copy {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.token-line {
  display: block;
  margin-top: 12rpx;
}

.banner {
  margin-top: 28rpx;
  padding: 28rpx;
  border: 1rpx solid var(--line);
  background: var(--card);
}

.banner.free {
  border-color: rgba(119, 128, 95, 0.45);
  background: rgba(119, 128, 95, 0.08);
}

.banner.soft {
  border-style: dashed;
}

.banner-title {
  display: block;
  font-weight: 600;
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.banner-body {
  display: block;
  color: var(--muted);
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.banner-btn {
  margin-top: 16rpx;
}

.section-title {
  display: block;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.section-head .section-title {
  margin-bottom: 0;
}

.link {
  color: var(--olive);
  font-size: 24rpx;
}

.hero-agent {
  padding: 28rpx;
  border: 1rpx solid var(--ink);
  background: var(--card);
}

.agent-row-item {
  padding: 20rpx 0;
  border-top: 1rpx solid var(--line);
}

.agent-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.agent-name {
  font-size: 30rpx;
  font-weight: 500;
}

.tag {
  font-size: 20rpx;
  color: var(--olive);
}

.gap {
  margin-top: 20rpx;
}
