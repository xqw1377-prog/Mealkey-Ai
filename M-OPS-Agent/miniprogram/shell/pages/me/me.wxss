.page {
  padding: 40rpx 36rpx 80rpx;
}

.banner {
  margin-top: 24rpx;
  padding: 28rpx;
  border: 1rpx solid var(--line);
  background: var(--card);
}

.banner-title {
  display: block;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.banner-body {
  display: block;
  color: var(--muted);
  font-size: 24rpx;
}

.section {
  margin-top: 36rpx;
}

.section-title {
  display: block;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.input {
  margin-top: 16rpx;
  padding: 20rpx;
  border: 1rpx solid var(--line);
  background: #fff;
}

.ledger {
  padding: 12rpx 0;
  border-top: 1rpx solid var(--line);
}

.gap {
  margin-top: 20rpx;
}
