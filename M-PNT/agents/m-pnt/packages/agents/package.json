{
  "name": "@mealkey/agents",
  "version": "1.0.0",
  "private": true,
  "description": "MealKey specialized agents (M-PNT positioning agent)",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./m-pnt": "./src/m-pnt/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/manifest.test.ts tests/workflow.test.ts tests/capabilities.test.ts tests/distillation.test.ts tests/matrix-debate.test.ts tests/matrix-debate-output.test.ts tests/integration-report.ts",
    "demo:xiangcai": "tsx src/m-pnt/demo-xiangcai.ts",
    "demo:xiangcai-v1": "tsx src/m-pnt/demo-xiangcai.ts --runtime-v1",
    "test:v1": "tsx --test tests/decision-engine.test.ts tests/runtime-v1.test.ts",
    "test:all": "npm run test && npm run test:v1"
  },
  "dependencies": {
    "@mealkey/agent-sdk": "file:../agent-sdk"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
