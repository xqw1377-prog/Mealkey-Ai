page {
  --mk-bg: #f6f3ed;
  --mk-ink: #1c1f18;
  --mk-muted: #6b7260;
  --mk-accent: #66735e;
  --mk-accent-strong: #3d4634;
  --mk-card: #ffffff;
  --mk-line: rgba(61, 70, 52, 0.12);
  background: var(--mk-bg);
  color: var(--mk-ink);
  font-family: "PingFang SC", "Noto Sans SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.mk-page {
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
  box-sizing: border-box;
}

.mk-brand {
  font-size: 22rpx;
  letter-spacing: 0.08em;
  color: var(--mk-muted);
  margin-bottom: 8rpx;
}

.mk-title {
  font-size: 44rpx;
  font-weight: 650;
  line-height: 1.25;
  margin: 0 0 12rpx;
}

.mk-sub {
  font-size: 26rpx;
  color: var(--mk-muted);
  margin: 0 0 28rpx;
}

.mk-card {
  background: var(--mk-card);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--mk-line);
}

.mk-card-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.mk-card-sub {
  font-size: 24rpx;
  color: var(--mk-muted);
  margin-bottom: 20rpx;
}

.mk-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.mk-tag {
  font-size: 22rpx;
  color: var(--mk-accent-strong);
  background: rgba(102, 115, 94, 0.12);
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.mk-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: var(--mk-accent-strong);
  color: #f6f3ed;
  font-size: 30rpx;
  font-weight: 600;
}

.mk-btn::after {
  border: none;
}

.mk-btn-ghost {
  background: transparent;
  color: var(--mk-accent-strong);
  border: 2rpx solid rgba(61, 70, 52, 0.28);
}

.mk-meta {
  font-size: 22rpx;
  color: var(--mk-muted);
  margin-top: 12rpx;
}

.mk-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--mk-line);
}

.mk-row:last-child {
  border-bottom: none;
}

.mk-label {
  color: var(--mk-muted);
  font-size: 24rpx;
}

.mk-value {
  font-size: 28rpx;
  font-weight: 550;
}

.mk-input {
  background: #f3f0e9;
  border-radius: 16rpx;
  padding: 20rpx 22rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

.mk-field-label {
  font-size: 22rpx;
  color: var(--mk-muted);
  margin-bottom: 8rpx;
}
