generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

// 开发环境用 SQLite，生产环境用 PostgreSQL
// 通过 DATABASE_URL 控制：file:./dev.db 或 postgresql://...
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// MealKey OS Kernel Schema V1
//
// 8 核心对象，对齐 7 Frozen Protocols
//
// Protocol 1: Context → Owner + Project + Memory + Decision + Knowledge
// Protocol 2: Decision → Decision
// Protocol 3: Memory → Memory
// Protocol 4: Agent Manifest → AgentProduct
// Protocol 5: Capability → CapabilityModule
// Protocol 6: Mission → Mission
// Protocol 7: Agent Run → AgentRun
// ═══════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════
// 认证系统（不属于 Kernel，支撑登录）
// ═══════════════════════════════════════════════════════════════

model User {
  id            String   @id @default(cuid())
  email         String?  @unique
  passwordHash  String?
  name          String?
  image         String?
  onboarded     Boolean  @default(false)
  preferences   String?  // JSON

  // 关联
  owner         Owner?
  conversations Conversation[]
  passwordResetTokens PasswordResetToken[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// 一次性密码重置（只存 token 哈希；明文链接仅签发时返回给管理员/开发日志）
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  requestedFrom String? // forgot | admin

  @@index([userId])
  @@index([expiresAt])
}

// ═══════════════════════════════════════════════════════════════
// Kernel Object 1: Owner（经营者）
// 对齐 Protocol 1: OwnerContext
// ═══════════════════════════════════════════════════════════════

model Owner {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 基础信息
  name            String?
  email           String?

  // 经营者画像（对齐 OwnerContext）
  experience      String   @default("0年")     // "餐饮3年"
  background      String   @default("{}")      // JSON: { product, operation, brand, finance }
  overallScore    Int      @default(50)        // 0-100
  strengths       String   @default("[]")      // JSON: ["产品", "运营"]
  weaknesses      String   @default("[]")      // JSON: ["品牌战略"]
  riskTolerance   String   @default("medium")  // low | medium | high
  investmentStyle String   @default("moderate") // conservative | moderate | aggressive

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // 关联
  projects        Project[]
  memories        Memory[]
  decisions       Decision[]
  missions        Mission[]        @relation("MissionSource")
  agentRuns       AgentRun[]
  capabilities    OwnerCapability[]
  assessments     CognitionAssessment[]
  strategies      StrategyDocument[]
  assetCategories AssetCategory[]
  assets          Asset[]
}

// ═══════════════════════════════════════════════════════════════
// Kernel Object 2: Project（经营项目）
// 对齐 Protocol 1: ProjectContext
// ═══════════════════════════════════════════════════════════════

model Project {
  id          String   @id @default(cuid())
  ownerId     String
  owner       Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  description String?
  status      String   @default("active")   // active | archived | paused
  stage       String   @default("idea")     // idea | positioning | location | setup | opening | growth

  // 对齐 ProjectContext
  category    String?  // "湘菜"
  target      String?  // "年轻消费者"
  city        String?
  district    String?
  budget      Float?   // 500000
  profile     String?  // JSON: 扩展信息
  currentGoal String?
  healthScore Int?
  confidence  Float?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关联
  memories    Memory[]
  decisions   Decision[]
  agentRuns   AgentRun[]
  reports     Report[]
  conversations Conversation[]
  assets      Asset[]
  restaurant  Restaurant?

  @@index([ownerId])
  @@index([status])
  @@index([stage])
}

// ═══════════════════════════════════════════════════════════════
// Restaurant Brain V1 — 规范化实体（事实 Fact ≠ 判断 Decision）
// 权威：docs/MEALKEY_RESTAURANT_BRAIN_PRISMA_ENTITY_V1.md
// JSON 字段以 String 存（与全库一致），API 层解析
// ═══════════════════════════════════════════════════════════════

model Restaurant {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ownerId   String
  name      String
  status    String   @default("active") // active | archived | paused
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile    RestaurantProfile?
  brand      BrandProfile?
  business   BusinessProfile?
  capability CapabilityProfile?
  founder    FounderProfile?
  decisions  DecisionRecord[]
  actions    ActionRecord[]
  learnings  BrainLearning[]
  events     BrainEvent[]
  evolution  EvolutionState?

  @@index([ownerId])
  @@index([status])
}

model RestaurantProfile {
  id           String   @id @default(cuid())
  restaurantId String   @unique
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category     String   @default("")
  stage        String   @default("unknown") // idea|opening|growth|mature|expansion|unknown
  city         String?
  storeCount   Int      @default(1)
  priceRange   String?
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BrandProfile {
  id                    String   @id @default(cuid())
  restaurantId          String   @unique
  restaurant            Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  positioning           String?
  targetCustomer        String?
  consumptionScene      String?
  brandPromise          String?
  competitiveAdvantage  String?
  brandRisk             String?
  confidence            Float    @default(0.5)
  updatedAt             DateTime @updatedAt
}

model BusinessProfile {
  id             String   @id @default(cuid())
  restaurantId   String   @unique
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  monthlyRevenue Float?
  grossMargin    Float?
  netMargin      Float?
  averageTicket  Float?
  dailyOrders    Int?
  laborRatio     Float?
  rentRatio      Float?
  businessModel  String?
  updatedAt      DateTime @updatedAt
}

model CapabilityProfile {
  id                 String   @id @default(cuid())
  restaurantId       String   @unique
  restaurant         Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  strategyScore      Int      @default(0)
  marketScore        Int      @default(0)
  productScore       Int      @default(0)
  financeScore       Int      @default(0)
  operationScore     Int      @default(0)
  organizationScore  Int      @default(0)
  overallScore       Int      @default(0)
  confidence         Float    @default(0)
  updatedAt          DateTime @updatedAt
}

model FounderProfile {
  id              String   @id @default(cuid())
  restaurantId    String   @unique
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  experience      String?
  decisionStyle   String?
  riskPreference  String?
  strengthsJson   String?  // JSON string[]
  weaknessesJson  String?
  blindSpotsJson  String?
  growthTrendJson String?
  updatedAt       DateTime @updatedAt
}

model DecisionRecord {
  id                 String   @id @default(cuid())
  restaurantId       String
  restaurant         Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  mkDecisionId       String?  @unique // 可选挂接 Prisma Decision
  type               String   @default("general")
  question           String
  contextJson        String?  // 当时事实快照（非答案）
  optionsJson        String?
  chosenOption       String?
  aiAssessmentJson   String?
  councilResultJson  String?
  expectedOutcomeJson String?
  actualOutcomeJson  String?
  learningGenerated  Boolean  @default(false)
  status             String   @default("open")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  actions ActionRecord[]

  @@index([restaurantId, createdAt])
  @@index([type])
  @@index([status])
}

model ActionRecord {
  id           String    @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  decisionId   String?
  decision     DecisionRecord? @relation(fields: [decisionId], references: [id], onDelete: SetNull)
  action       String
  owner        String?
  deadline     DateTime?
  status       String    @default("pending")
  resultJson   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([restaurantId, createdAt])
  @@index([decisionId])
  @@index([status])
}

/// Brain 学习记忆（与认知内核 LearningRecord 区分）
model BrainLearning {
  id           String   @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  sourceType   String
  sourceId     String?
  pattern      String
  insight      String
  confidence   Float    @default(0.5)
  appliedCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([restaurantId, createdAt])
  @@index([pattern])
}

model BrainEvent {
  id           String   @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  type         String
  payloadJson  String
  source       String   @default("system")
  createdAt    DateTime @default(now())

  @@index([restaurantId, createdAt])
  @@index([type, createdAt])
}

model EvolutionState {
  id                 String    @id @default(cuid())
  restaurantId       String    @unique
  restaurant         Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  understandingScore Int       @default(0)
  dataCompleteness   Int       @default(0)
  decisionCount      Int       @default(0)
  learningCount      Int       @default(0)
  actionCount        Int       @default(0)
  lastEvolutionAt    DateTime?
  updatedAt          DateTime  @updatedAt
}

// ═══════════════════════════════════════════════════════════════
// Kernel Object 3: Memory（记忆）
// 对齐 Protocol 3: MemoryEngine
//
// 四类记忆：owner / project / decision / learning
// ═══════════════════════════════════════════════════════════════

model Memory {
  id        String   @id @default(cuid())
  ownerId   String
  owner     Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 对齐 MemoryContext
  type      String   // OWNER | PROJECT | DECISION | LEARNING
  key       String
  content   String   // 记忆内容（文本或 JSON）
  importance Int     @default(50)  // 0-100
  source    String   @default("ai") // user | ai | feedback

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, projectId, key])
  @@index([ownerId])
  @@index([projectId])
  @@index([type])
}

/// 跨租户行业洞察池（脱敏后；无 owner 外键，仅 contributorHash）
/// User Intelligence Evolution U4 · Memory Permission opt-in
model IndustryInsight {
  id              String   @id @default(cuid())
  category        String
  rule            String
  outcome         String   @default("unknown") // confirmed | partial | invalidated | unknown
  confidence      Float    @default(0.4)
  evidenceLevel   String   @default("validated_outcome")
  sourceKind      String   // validation | override | decision_pattern
  anonymizedJson  String   // JSON：无 PII 结构化摘要
  contributorHash String   // 单向哈希，不可反查 owner
  fingerprint     String   // category+rule 去重键
  supportCount    Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([fingerprint])
  @@index([category])
  @@index([outcome, confidence])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
// Kernel Object 4: Decision（决策）
// 对齐 Protocol 2: MKDecision
//
// 判断链：observation → diagnosis → strategy → action
// ═══════════════════════════════════════════════════════════════

model Decision {
  id          String   @id @default(cuid())
  ownerId     String
  owner       Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agentRunId  String?
  agentRun    AgentRun? @relation(fields: [agentRunId], references: [id])
  agentId     String?  // 来源 Agent ID

  // 对齐 MKDecision
  problem     String   // 问题是什么
  observation String   // 观察到了什么
  diagnosis   String   // 诊断结果
  judgement   String   // 判断结论
  strategy    String   // 策略建议
  action      String   // 具体行动
  confidence  Float    @default(0)  // 0-1
  evidence    String   @default("[]") // JSON: Evidence[]

  // 结果反馈（闭环）
  outcome     String?  // JSON: 实际结果
  learning    String?  // JSON: 学到的教训

  type        String   @default("general") // positioning | investment | product | marketing | risk
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
  @@index([projectId, createdAt])
  @@index([type])
  @@index([agentId])
}

model DecisionEvent {
  id            String   @id @default(cuid())
  decisionId    String
  eventType     String
  metadata      String?
  sourceEventId String?  @unique
  createdAt     DateTime @default(now())

  @@index([decisionId, createdAt])
  @@index([eventType, createdAt])
}

model CognitiveSession {
  id                 String    @id @default(cuid())
  agentRunId         String?
  projectId          String?
  decisionId         String?
  contextSnapshotRef String?
  status             String    @default("COMPLETED")
  confidenceRef      String?
  source             String    @default("decision_persistence")
  startedAt          DateTime  @default(now())
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([agentRunId, createdAt])
  @@index([projectId, createdAt])
  @@index([decisionId, createdAt])
  @@index([status, createdAt])
}

model CognitiveTrace {
  id            String    @id @default(cuid())
  sessionId     String
  type          String
  sourceType    String
  sourceId      String?
  input         String?
  output        String?
  confidence    Float?
  weight        Float?
  sequence      Int
  sourceEventId String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([sessionId, sequence])
  @@index([type, createdAt])
  @@index([sourceType, createdAt])
  @@index([sourceId])
}

model EvidenceReference {
  id           String    @id @default(cuid())
  sessionId    String
  decisionId   String?
  type         String
  sourceType   String
  sourceId     String
  contribution Float
  confidence   Float?
  content      String?
  metadata     String?
  createdAt    DateTime  @default(now())

  @@index([sessionId, createdAt])
  @@index([decisionId, createdAt])
  @@index([sourceType, sourceId])
}

model ConfidenceModel {
  id                   String    @id @default(cuid())
  sessionId            String    @unique
  overall              Float
  dataConfidence       Float?
  knowledgeConfidence  Float?
  ruleConfidence       Float?
  llmConfidence        Float?
  historicalConfidence Float?
  metadata             String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([overall, createdAt])
}

// ═══════════════════════════════════════════════════════════════
// Kernel Object 5: Mission（任务）
// 对齐 Protocol 6: Mission
//
// Agent 间不直接调用，通过 Mission 通信
// ═══════════════════════════════════════════════════════════════

model Mission {
  id           String   @id @default(cuid())
  sourceAgent  String   // 发起方 Agent ID
  targetAgent  String   // 目标 Agent ID
  ownerId      String
  owner        Owner    @relation("MissionSource", fields: [ownerId], references: [id], onDelete: Cascade)
  projectId    String?

  // 对齐 Mission
  objective    String   // "生成品牌定位方案"
  context      String   // JSON: MKContext（快照）
  status       String   @default("pending") // pending | running | completed | failed
  result       String?  // JSON: MKDecision

  // 元数据
  duration     Int      @default(0)  // ms

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([ownerId])
  @@index([sourceAgent])
  @@index([targetAgent])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════
// Kernel Object 6: AgentRun（执行记录）
// 对齐 Protocol 7: AgentRun
//
// 每一次 Agent 工作都记录：复盘、计费、优化、排错
// ═══════════════════════════════════════════════════════════════

model AgentRun {
  id           String   @id @default(cuid())
  agentId      String   // Agent ID
  ownerId      String
  owner        Owner    @relation(fields: [ownerId], references: [id])
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id])
  missionId    String?  // 关联 Mission
  conversationId String?

  // 对齐 AgentRun
  input        String?  // JSON: Partial<MKContext>
  output       String?  // JSON: MKDecision
  decisionId   String?  // 关联 Decision
  tokens       Int      @default(0)
  duration     Int      @default(0)  // ms
  status       String   @default("running") // running | success | failed

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // 关联
  decisions    Decision[]

  @@index([agentId])
  @@index([ownerId])
  @@index([projectId])
  @@index([missionId])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════
// Kernel Object 7: Capability（能力模块）
// 对齐 Protocol 5: CapabilityDefinition
//
// 能力不属于 Agent，能力属于系统
// ═══════════════════════════════════════════════════════════════

model CapabilityModule {
  id          String   @id @default(cuid())
  name        String   @unique  // "market-analysis"
  description String
  domain      String   @default("general") // startup | brand | finance | product | marketing
  version     String   @default("1.0.0")

  // 对齐 CapabilityDefinition
  inputSchema  String   // JSON Schema
  outputSchema String   // JSON Schema

  status      String   @default("active") // active | deprecated
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([domain])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════
// Kernel Object 8: Knowledge（知识）
// 对齐 Protocol 1: KnowledgeContext
//
// 三类知识：rules / cases / models
// ═══════════════════════════════════════════════════════════════

model KnowledgeNode {
  id         String             @id @default(cuid())
  title      String
  content    String
  categoryId String?
  category   KnowledgeCategory? @relation(fields: [categoryId], references: [id])

  // 对齐 KnowledgeContext
  type       String   @default("rule") // principle | rule | case | model | framework

  // 元数据
  tags       String   @default("[]")  // JSON array
  source     String?
  confidence Float    @default(0.8)
  relations  String?  // JSON

  status     String   @default("draft") // draft | published | archived
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([categoryId])
  @@index([type])
  @@index([status])
}

// ─── 知识分类 ───
model KnowledgeCategory {
  id        String              @id @default(cuid())
  name      String
  parentId  String?
  parent    KnowledgeCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  KnowledgeCategory[] @relation("CategoryTree")
  nodes     KnowledgeNode[]
  sortOrder Int                 @default(0)
  createdAt DateTime            @default(now())
}

// ═══════════════════════════════════════════════════════════════
// Agent 生态模型（Protocol 4: Agent Manifest）
// ═══════════════════════════════════════════════════════════════

// ─── Agent 产品（对齐 AgentManifest）───
model AgentProduct {
  id              String   @id @default(cuid())
  slug            String   @unique       // "launch-agent"
  name            String                 // "开店战略顾问"
  description     String
  version         String   @default("1.0.0")
  author          String   @default("MealKey")
  domain          String                 // startup | brand | finance | product | marketing

  // 对齐 AgentManifest
  capabilities    String   @default("[]") // JSON: ["market-analysis", "positioning"]
  requiredContext String   @default("[]") // JSON: ["owner", "project", "knowledge"]
  workflow        String   @default("")   // 工作流描述
  outputSchema    String   @default("")   // 输出 Schema 描述
  manifest        String   // JSON: 完整 manifest
  pricing         String   // JSON: { model, price, currency }

  status          String   @default("active") // active | deprecated | draft
  rating          Float    @default(0)
  installs        Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([domain])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════
// Platform Facts（Platform Migration V1）
//
// 先在旧 Kernel 之上补平台事实层：
// - PlatformEvent: 原始接入审计层
// - AgentTrace: 运行链路事实
// - AgentOutcome: 结果事实
// - UsageRecord: 资源消耗事实
//
// 当前 SQLite 阶段优先兼容落地，因此 JSON / Decimal 先用 String 存储
// ═══════════════════════════════════════════════════════════════

model PlatformEvent {
  id               String   @id @default(cuid())
  eventId          String   @unique
  eventName        String
  eventVersion     Int      @default(1)
  producer         String
  source           String
  entityType       String
  entityId         String
  agentId          String?
  versionId        String?
  runtimeId        String?
  runId            String?
  traceId          String?
  decisionId       String?
  projectId        String?
  organizationId   String?
  billingAccountId String?
  invoiceId        String?
  listingId        String?
  sequence         Int?
  idempotencyKey   String?
  payload          String
  rawBody          String
  occurredAt       DateTime
  receivedAt       DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([eventName, occurredAt])
  @@index([runId, occurredAt])
  @@index([traceId])
  @@index([billingAccountId, occurredAt])
  @@index([idempotencyKey])
}

model AgentTrace {
  id              String    @id @default(cuid())
  runId           String
  parentTraceId   String?
  type            String
  source          String
  name            String
  inputSnapshot   String?
  outputSnapshot  String?
  status          String
  errorCode       String?
  retryCount      Int       @default(0)
  latencyMs       Int?
  sequence        Int?
  sourceEventId   String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([runId, createdAt])
  @@index([status, createdAt])
  @@index([errorCode])
}

model AgentOutcome {
  id            String    @id @default(cuid())
  runId         String
  metricType    String
  value         String
  unit          String?
  source        String
  sourceEventId String?   @unique
  createdAt     DateTime  @default(now())

  @@index([runId, createdAt])
  @@index([metricType])
}

model UsageRecord {
  id               String    @id @default(cuid())
  runId            String?
  runtimeId        String?
  agentId          String?
  versionId        String?
  billingAccountId String?
  usageType        String
  provider         String?
  model            String?
  tokenInput       Int       @default(0)
  tokenOutput      Int       @default(0)
  tokenCached      Int       @default(0)
  tokenReasoning   Int       @default(0)
  tokenTotal       Int       @default(0)
  cost             String
  currency         String    @default("CNY")
  billable         Boolean   @default(true)
  externalUsageId  String?
  source           String
  sourceEventId    String?   @unique
  occurredAt       DateTime
  createdAt        DateTime  @default(now())

  @@index([runId, occurredAt])
  @@index([billingAccountId, occurredAt])
  @@index([usageType, occurredAt])
  @@index([externalUsageId])
}

// ═══════════════════════════════════════════════════════════════
// Platform Admin Objects（Admin Console V1）
//
// 在现有 Kernel 与 Platform Facts 之上补平台管理对象层：
// - Organization / OrganizationMember
// - BillingAccount / Plan / Subscription / CreditLedger / Invoice
// - AgentListing / RevenueShare
// - EvaluationResult / LearningRecord
// - KnowledgeEdge
// ═══════════════════════════════════════════════════════════════

model Organization {
  id          String   @id
  name        String
  slug        String   @unique
  type        String   @default("workspace")
  status      String   @default("active")
  ownerUserId String?
  metadata    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerUserId])
  @@index([status, createdAt])
}

model OrganizationMember {
  id              String   @id
  organizationId  String
  userId          String
  role            String   @default("OWNER")
  status          String   @default("active")
  invitedByUserId String?
  metadata        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([role, status])
}

model BillingAccount {
  id             String   @id
  organizationId String?
  ownerId        String?
  name           String
  status         String   @default("active")
  currency       String   @default("CNY")
  balance        String   @default("0")
  metadata       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([ownerId])
  @@index([status, createdAt])
}

model Plan {
  id             String   @id
  code           String   @unique
  name           String
  description    String?
  billingCycle   String   @default("MONTHLY")
  priceCents     Int      @default(0)
  currency       String   @default("CNY")
  includedTokens Int      @default(0)
  includedRuns   Int      @default(0)
  status         String   @default("active")
  metadata       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, billingCycle])
}

model Subscription {
  id                  String   @id
  billingAccountId    String
  planId              String
  status              String   @default("active")
  seats               Int      @default(1)
  startedAt           DateTime @default(now())
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  cancelAtPeriodEnd   Boolean  @default(false)
  metadata            String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([billingAccountId, status])
  @@index([planId, status])
}

model CreditLedger {
  id               String   @id
  billingAccountId String
  entryType        String
  amount           String
  currency         String   @default("CNY")
  balanceAfter     String?
  description      String?
  sourceType       String?
  sourceId         String?
  createdAt        DateTime @default(now())

  @@index([billingAccountId, createdAt])
  @@index([entryType, createdAt])
}

model Invoice {
  id               String   @id
  billingAccountId String
  invoiceNo        String   @unique
  status           String   @default("draft")
  subtotal         String   @default("0")
  tax              String   @default("0")
  total            String   @default("0")
  currency         String   @default("CNY")
  issuedAt         DateTime?
  paidAt           DateTime?
  metadata         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([billingAccountId, createdAt])
  @@index([status, createdAt])
}

/// 微信支付 / 支付宝套餐订单
model PaymentOrder {
  id               String    @id @default(cuid())
  orderNo          String    @unique
  userId           String
  ownerId          String
  billingAccountId String
  planId           String
  channel          String // wechat | alipay | sandbox
  status           String    @default("pending") // pending | paid | failed | closed | refunded
  amountCents      Int
  currency         String    @default("CNY")
  providerTradeNo  String?
  codeUrl          String?
  payUrl           String?
  paidAt           DateTime?
  metadata         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([billingAccountId, status])
  @@index([status, createdAt])
  @@index([providerTradeNo])
}

/// 经营点钱包（余额真相源）
model UserWallet {
  id             String   @id @default(cuid())
  userId         String   @unique
  balance        Int      @default(0)
  totalPurchased Int      @default(0)
  totalConsumed  Int      @default(0)
  frozenAmount   Int      @default(0)
  status         String   @default("active") // active | frozen
  metadata       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, updatedAt])
}

/// 经营点流水
model WalletLedger {
  id           String   @id @default(cuid())
  userId       String
  walletId     String
  amount       Int
  balanceAfter Int
  type         String // PURCHASE | CONSUME | REFUND | BONUS | RESERVE | RELEASE | SETTLE | ADJUST
  reason       String
  referenceId  String?
  metadata     String?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([walletId, createdAt])
  @@index([type, createdAt])
  @@index([referenceId])
}

/// 能力定价规则
model CapabilityPrice {
  id                     String   @id @default(cuid())
  capability             String   @unique
  baseCost               Int
  depthMultipliers       String   @default("{}")
  complexityMultipliers  String   @default("{}")
  modelMultipliers       String   @default("{}")
  dataMultipliers        String   @default("{}")
  agentMultipliers       String   @default("{}")
  active                 Boolean  @default(true)
  metadata               String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([active])
}

/// 能力消耗记录（预授权 → 结算 / 退款）
model ConsumptionRecord {
  id               String   @id @default(cuid())
  userId           String
  walletId         String
  capability       String
  agentCodes       String   @default("[]")
  requestedAmount  Int
  actualAmount     Int      @default(0)
  status           String   @default("AUTHORIZED") // AUTHORIZED | SETTLED | FAILED | REFUNDED
  reason           String
  pricingSnapshot  String?
  runId            String?
  tokenInput       Int      @default(0)
  tokenOutput      Int      @default(0)
  tokenCached      Int      @default(0)
  tokenReasoning   Int      @default(0)
  tokenTotal       Int      @default(0)
  model            String?
  provider         String?
  costCents        Int      @default(0)
  metadata         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([walletId, createdAt])
  @@index([status, createdAt])
  @@index([capability, createdAt])
  @@index([runId])
}

/// 按 Agent 授权（矩阵节点可独立开通）
model AgentEntitlement {
  id               String    @id @default(cuid())
  billingAccountId String
  agentCode        String // chief | m-mkt | m-pnt | m-ed | m-biz
  status           String    @default("active") // active | expired | revoked
  source           String    @default("plan") // plan | addon | grant
  planId           String?
  subscriptionId   String?
  startedAt        DateTime  @default(now())
  endsAt           DateTime?
  metadata         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([billingAccountId, agentCode])
  @@index([billingAccountId, status])
  @@index([agentCode, status])
}

model AgentListing {
  id            String   @id
  agentProductId String?
  slug          String   @unique
  name          String
  description   String?
  status        String   @default("active")
  visibility    String   @default("public")
  pricingModel  String   @default("subscription")
  priceCents    Int      @default(0)
  currency      String   @default("CNY")
  installCount  Int      @default(0)
  rating        Float    @default(0)
  metadata      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([agentProductId])
  @@index([status, visibility])
}

model RevenueShare {
  id              String   @id
  listingId       String
  beneficiaryType String
  beneficiaryId   String
  sharePercent    Float
  status          String   @default("active")
  metadata        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([listingId, status])
  @@index([beneficiaryType, beneficiaryId])
}

model EvaluationResult {
  id         String   @id
  agentRunId String?
  decisionId String?
  evaluator  String
  score      Float?
  verdict    String
  summary    String?
  metadata   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([agentRunId, createdAt])
  @@index([decisionId, createdAt])
  @@index([verdict, createdAt])
}

model LearningRecord {
  id                 String   @id
  decisionId         String?
  evaluationResultId String?
  sourceType         String
  sourceId           String?
  title              String
  summary            String?
  status             String   @default("pending")
  weightDelta        Float?
  metadata           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([decisionId, createdAt])
  @@index([evaluationResultId])
  @@index([status, createdAt])
}

model KnowledgeEdge {
  id           String   @id
  fromNodeId   String
  toNodeId     String
  relationType String
  weight       Float?
  metadata     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([fromNodeId])
  @@index([toNodeId])
  @@index([relationType])
}

// ═══════════════════════════════════════════════════════════════
// 交互系统（不属于 Kernel，支撑对话）
// ═══════════════════════════════════════════════════════════════

// ─── 对话 ───
model Conversation {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id])
  agentType    String?  // chief | brand | location | finance
  title        String?
  summary      String?
  messageCount Int      @default(0)
  messages     Message[]
  assets       Asset[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([projectId])
}

// ─── 消息 ───
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // user | assistant | tool
  content        String
  toolName       String?
  toolArgs       String?      // JSON
  toolResult     String?      // JSON
  metadata       String?      // JSON: { model, latency, tokens, decisionId }
  assets         Asset[]
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

model AssetCategory {
  id          String   @id @default(cuid())
  ownerId     String
  owner       Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  scope       String   @default("owner") // owner | project | knowledge
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assets      Asset[]

  @@unique([ownerId, slug])
  @@index([ownerId])
  @@index([scope])
}

model Asset {
  id             String         @id @default(cuid())
  ownerId        String
  owner          Owner          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   Conversation?  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messageId      String?
  message        Message?       @relation(fields: [messageId], references: [id], onDelete: SetNull)
  categoryId     String?
  category       AssetCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  kind           String         // audio | image | video | document
  title          String
  fileName       String
  mimeType       String
  extension      String?
  sizeBytes      Int
  storagePath    String
  publicUrl      String

  status         String         @default("ready") // uploading | processing | ready | failed
  tags           String         @default("[]")
  transcript     String?
  extractedText  String?
  summary        String?
  metadata       String?        // JSON

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([ownerId])
  @@index([projectId])
  @@index([conversationId])
  @@index([messageId])
  @@index([categoryId])
  @@index([kind])
  @@index([status])
}

// ─── 报告 ───
model Report {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type         String   // diagnosis | strategy | monthly | location | menu | custom
  title        String
  summary      String?
  content      String?  // JSON
  decisionIds  String?  // JSON: 关联决策ID
  status       String   @default("draft")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([projectId])
  @@index([type])
}

// ─── 经营者能力评估（辅助模型）───
model OwnerCapability {
  id          String   @id @default(cuid())
  ownerId     String
  owner       Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  category    String
  score       Int      @default(50)
  evidence    String   @default("{}")
  improvement String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([ownerId, name])
  @@index([ownerId])
}

// ─── 认知评估记录（辅助模型）───
model CognitionAssessment {
  id        String   @id @default(cuid())
  ownerId   String
  owner     Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  topic     String
  framework String
  before    String
  analysis  String
  after     String?
  outcome   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([topic])
}

// ─── 战略文档（辅助模型）───
model StrategyDocument {
  id        String   @id @default(cuid())
  ownerId   String
  owner     Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  type      String
  title     String
  content   String
  version   Int      @default(1)
  status    String   @default("draft")
  projectId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([type])
}
