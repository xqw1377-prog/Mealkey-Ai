{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Council Opinion",
  "type": "object",
  "required": [
    "member",
    "position",
    "confidence",
    "summary",
    "reasoning",
    "risks",
    "conditions",
    "veto"
  ],
  "properties": {
    "member": { "type": "string" },
    "position": {
      "type": "string",
      "enum": ["support", "oppose", "conditional"]
    },
    "confidence": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "weight": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "summary": { "type": "string" },
    "reasoning": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence_used": {
      "type": "array",
      "items": { "type": "string" }
    },
    "key_assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "conditions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "challenge_to_others": {
      "type": "array",
      "items": { "type": "string" }
    },
    "response_to_challenges": {
      "type": "array",
      "items": { "type": "string" }
    },
    "veto": { "type": "boolean" },
    "veto_reason": { "type": "string" },
    "change_of_view": { "type": "boolean" },
    "change_reason": { "type": "string" },
    "minority_report": { "type": "boolean" },
    "prediction": {
      "type": "object",
      "properties": {
        "best_case": { "type": "string" },
        "base_case": { "type": "string" },
        "worst_case": { "type": "string" },
        "kill_metric": { "type": "string" }
      }
    }
  }
}
