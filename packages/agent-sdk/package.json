{
  "name": "@mealkey/agent-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "MealKey Agent SDK - 7 Protocols + Platform Gateway Client（外接 Agent；无垂直业务）",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./platform": {
      "types": "./src/platform/index.ts",
      "import": "./src/platform/index.ts",
      "default": "./src/platform/index.ts"
    },
    "./mini-shell": {
      "types": "./src/mini-shell/index.ts",
      "import": "./src/mini-shell/index.ts",
      "default": "./src/mini-shell/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
